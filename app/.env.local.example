# Percolator Launch — Environment Variables
# Copy this to .env.local and fill in your values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# API auth (required for indexer/mutation endpoints)
INDEXER_API_KEY="your-api-key"

# Solana (optional — defaults to devnet)
# NEXT_PUBLIC_RPC_URL="https://api.devnet.solana.com"
# NEXT_PUBLIC_NETWORK="devnet"
# NEXT_PUBLIC_PROGRAM_ID="GM8zjJ8LTBMv9xEsverh6H6wLyevgMHEJXcEzyY3rY24"

# Privy wallet integration
NEXT_PUBLIC_PRIVY_APP_ID=
# Server-side Privy app secret — required for /api/waitlist/whoami and the
# Privy-DID linkage in /api/waitlist/signup. Generate it in the Privy
# dashboard (App Settings → API Keys). Without it both routes degrade
# gracefully (the form still works, just no auto-detection of returning users).
PRIVY_APP_SECRET=

# Admin allowlist — two mechanisms, either is sufficient.
#
# PRIVY_ADMIN_DIDS: comma-separated Privy DIDs. Preferred — the DID is
# the most stable identity (doesn't depend on which email Privy treats
# as primary, doesn't drift when OAuth accounts link/unlink). Prefix
# `did:privy:` is optional; we strip on both sides.
# Example: PRIVY_ADMIN_DIDS=cmp7lntno008b0dl7o0sh8o2x,did:privy:abc123…
PRIVY_ADMIN_DIDS=
#
# PRIVY_ADMIN_EMAILS: comma-separated emails (lowercased). Matched
# against ANY of the user's verified emails. Useful for onboarding when
# you don't have the new admin's DID yet, less reliable than DID.
# Example: PRIVY_ADMIN_EMAILS=dark@percolator.trade,squid@percolator.trade
PRIVY_ADMIN_EMAILS=
