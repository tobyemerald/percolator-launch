# =============================================================================
# Percolator Keeper — Mainnet Environment Variables
# =============================================================================
# Railway service: oracle-keeper-mainnet
# Copy this file, fill in values, then set via Railway CLI or dashboard.
# DO NOT commit filled-in values to git.
# =============================================================================

# --- Solana ---
# Helius mainnet RPC (paid plan — same key as API service)
# NOTE: Keeper uses RPC_URL (not SOLANA_RPC_URL) — env guard checks this var.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=<HELIUS_MAINNET_API_KEY>
FALLBACK_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS_URL=wss://mainnet.helius-rpc.com/?api-key=<HELIUS_MAINNET_API_KEY>

# --- Keeper Wallet ---
# Base58-encoded private key for the crank wallet
# Keypair file: ~/.percolator-mainnet/keys/keeper-mainnet.json
# Public key: 8y7sXswvGo6fWa4daCnxaE3znaFoBs6QJXLTzCLYXotV
# Must be funded with SOL for transaction fees (~0.5 SOL minimum)
KEEPER_PRIVATE_KEY=<BASE58_PRIVATE_KEY>

# --- Program ---
PROGRAM_ID=ESa89R5Es3rJ5mnwGybVRG1GrNt9etP11Z5V2QWD4edv

# --- Network ---
NETWORK=mainnet
FORCE_MAINNET=1

# --- Supabase (market registry) ---
SUPABASE_URL=<SUPABASE_PROJECT_URL>
# WARNING: Keeper gets ANON key only — NOT service_role.
# The env guard will exit(1) if it detects a service_role key here.
SUPABASE_KEY=<SUPABASE_ANON_KEY>

# --- Helius ---
HELIUS_MAINNET_API_KEY=<HELIUS_MAINNET_API_KEY>

# --- Keeper Registration ---
# Generate: openssl rand -hex 32
KEEPER_REGISTER_SECRET=<GENERATE_ME>

# --- Health Check ---
KEEPER_HEALTH_PORT=8081

# --- Sentry (error tracking) ---
SENTRY_DSN=https://9d5b46f4539d8868d6afe92dee953ba3@o4510225747738624.ingest.de.sentry.io/4510899260293200
SENTRY_ENVIRONMENT=production
